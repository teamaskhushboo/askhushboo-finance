rules_version = '2';

// #AS KHUSHBOO Finance - SECURE Firestore Rules
// =====================================================
// These rules DENY ALL client-side access (browser SDK).
// All data operations MUST go through server-side API routes
// that use Firebase Admin SDK (which bypasses these rules).
//
// This prevents anyone from reading, modifying, or deleting
// your financial data even if they extract the Firebase config
// from the browser bundle.

service cloud.firestore {
  match /databases/{database}/documents {

    // Default: DENY ALL access from client SDK
    match /{document=**} {
      allow read, write: if false;
    }

    // All collections explicitly denied (defense in depth)
    match /finance_expenses/{docId} {
      allow read, write: if false;
    }

    match /finance_revenue/{docId} {
      allow read, write: if false;
    }

    match /finance_settings/{docId} {
      allow read, write: if false;
    }
  }
}
